<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Support – USB CoverFix Deluxe</title>
    
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <style>
        /* ---------- СБРОС И КОМПАКТНЫЙ МОБИЛЬНЫЙ ДИЗАЙН ---------- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', 'Courier New', monospace;
        }

        html, body {
            width: 100%;
            overflow-x: hidden;
            background: #0a0e12;
        }

        body {
            color: #e0e0e0;
            line-height: 1.3;
            padding: 6px;
        }

        .container {
            background: #151e26;
            border-radius: 16px;
            padding: 12px 10px;
            border: 2px solid #2ecc71;
            max-width: 100%;
            margin: 0 auto;
        }

        h1 {
            font-size: 1.8rem;
            background: linear-gradient(45deg, #2ecc71, #f1c40f);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-align: center;
            margin-bottom: 5px;
            line-height: 1.1;
        }

        .subhead {
            text-align: center;
            font-size: 1rem;
            color: #95a5a6;
            margin-bottom: 20px;
            border-bottom: 1px dashed #2ecc71;
            padding-bottom: 15px;
        }

        /* ---------- КНОПКИ ПОДДЕРЖКИ ---------- */
        .support-options {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin: 20px 0;
        }

        .support-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            width: 100%;
            background: #1e2a36;
            color: #e0e0e0;
            font-weight: bold;
            padding: 16px 12px;
            border-radius: 50px;
            text-decoration: none;
            font-size: 1.2rem;
            text-align: center;
            border: 1px solid #2ecc71;
            box-shadow: 0 4px 8px rgba(0,0,0,0.3);
            transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
        }

        .support-btn i {
            font-size: 1.8rem;
            color: #2ecc71;
        }

        .support-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(46,204,113,0.3);
            background: #2a3a48;
        }

        .btn-email {
            border-left: 6px solid #e74c3c;
        }
        .btn-github {
            border-left: 6px solid #f39c12;
        }
        .btn-instagram {
            border-left: 6px solid #e1306c;
        }
        .btn-back {
            border-left: 6px solid #2ecc71;
            background: #0f1a24;
        }

        .btn-back i {
            color: #f1c40f;
        }

        /* Текст описания под кнопками */
        .support-note {
            text-align: center;
            font-size: 0.8rem;
            color: #95a5a6;
            margin: 20px 0 10px;
        }

        /* Футер */
        .footer {
            margin-top: 20px;
            padding-top: 15px;
            border-top: 1px solid #2ecc71;
            text-align: center;
            font-size: 0.7rem;
            color: #95a5a6;
        }

        .footer a {
            color: #2ecc71;
            text-decoration: none;
        }

        .footer img {
            height: 18px;
            vertical-align: middle;
            margin-right: 3px;
        }

        /* ---------- ДЕСКТОПНАЯ ВЕРСИЯ ---------- */
        @media (min-width: 768px) {
            body { padding: 20px; }
            .container { max-width: 600px; padding: 30px; border-radius: 32px; margin: 0 auto; }
            h1 { font-size: 2.5rem; }
            .subhead { font-size: 1.2rem; }
            .support-btn { font-size: 1.5rem; padding: 20px; }
            .support-note { font-size: 0.9rem; }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🛟 Support Center</h1>
        <div class="subhead">Выберите удобный способ связи</div>

        <div class="support-options">
            <!-- Email -->
            <a href="mailto:usbcoverfix@gmail.com" class="support-btn btn-email">
                <i class="fas fa-envelope"></i>
                <span>Написать на почту</span>
                <i class="fas fa-chevron-right" style="margin-left: auto; font-size: 1rem; opacity: 0.7;"></i>
            </a>

            <!-- GitHub Issues -->
            <a href="https://github.com/scheck2019-png/USB_CoverFix_Deluxe/issues" target="_blank" class="support-btn btn-github">
                <i class="fab fa-github"></i>
                <span>Сообщить о проблеме (GitHub)</span>
                <i class="fas fa-chevron-right" style="margin-left: auto; font-size: 1rem; opacity: 0.7;"></i>
            </a>

            <!-- Instagram -->
            <a href="https://instagram.com/твой_никнейм" target="_blank" class="support-btn btn-instagram">
                <i class="fab fa-instagram"></i>
                <span>Сообщество в Instagram</span>
                <i class="fas fa-chevron-right" style="margin-left: auto; font-size: 1rem; opacity: 0.7;"></i>
            </a>
        </div>

        <p class="support-note">
            <i class="fas fa-clock"></i> Обычно отвечаем в течение 24 часов.<br>
            Для срочных вопросов используйте email.
        </p>

        <!-- Кнопка возврата на главную -->
        <a href="index.html" class="support-btn btn-back" style="margin-top: 20px;">
            <i class="fas fa-arrow-left"></i>
            <span>Вернуться на главную</span>
        </a>

        <!-- Футер -->
        <div class="footer">
            <img src="logo_mini5.png" alt="Logo"> © Siegfried Scheck<br>
            <a href="index.html">USB CoverFix Deluxe</a> | 
            <a href="https://github.com/scheck2019-png/USB_CoverFix_Deluxe">GitHub</a>
        </div>
    </div>
</body>
</html>
